# Copy to your host's environment/secret settings. Do NOT commit real values.

# Ed25519 signing PRIVATE key (PKCS8 PEM). Keep the newlines (use \n if your
# host needs a single line). This is the key generated alongside the app; its
# public half is embedded in app/core/license.py.
LICENSE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
...your key...
-----END PRIVATE KEY-----"

# Signing secret of the Paddle notification destination (Developer tools ->
# Notifications -> your destination). Used to verify incoming webhooks.
PADDLE_WEBHOOK_SECRET=pdl_ntfset_...

# Paddle API key (Developer tools -> Authentication) to look up the buyer email.
PADDLE_API_KEY=pdl_live_apikey_...

# Only mint for this price.
PADDLE_PRICE_ID=pri_01ky2hekjfm1c9nspf5pnqv0jv

# Resend (https://resend.com) for delivering the license email.
RESEND_API_KEY=re_...
LICENSE_FROM_EMAIL=licenses@yourdomain.com

# Optional overrides:
# PADDLE_API_BASE=https://api.paddle.com          # sandbox: https://sandbox-api.paddle.com
# LICENSE_PRODUCT_ID=easypost-desktop             # must match app/core/license.py
