<?xml version="1.0" encoding="utf-8"?>
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="SFields.Easy-PostDesktop"
    Publisher="CN=A7D4B6C0-27D4-4F66-82EB-82F5DD466788"
    Version="1.0.3.0"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Easy-Post Desktop</DisplayName>
    <PublisherDisplayName>SFields</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <!--
    Store listing languages. Each language declared here becomes a Store
    listing in Partner Center. This declares all 47 of the app's 50 runtime
    locales that the Microsoft Store supports (the Store's language list has
    no code for Javanese, Burmese or Somali, so those 3 cannot be declared as
    listing languages, though the app still runs in them at runtime via
    app/resources/locales/*.json). The per-language Store listings
    (description + screenshots) are populated in Partner Center via the
    Import/export listings feature. Keep this set of 47 in sync with the live
    submission's listing languages.
  -->
  <Resources>
    <Resource Language="en-us" />
    <Resource Language="zh-Hans" />
    <Resource Language="hi" />
    <Resource Language="es" />
    <Resource Language="fr" />
    <Resource Language="ar" />
    <Resource Language="bn" />
    <Resource Language="pt" />
    <Resource Language="ru" />
    <Resource Language="ur" />
    <Resource Language="id" />
    <Resource Language="de" />
    <Resource Language="ja" />
    <Resource Language="mr" />
    <Resource Language="te" />
    <Resource Language="tr" />
    <Resource Language="ta" />
    <Resource Language="vi" />
    <Resource Language="ko" />
    <Resource Language="fa" />
    <Resource Language="ha" />
    <Resource Language="sw" />
    <Resource Language="it" />
    <Resource Language="pa" />
    <Resource Language="gu" />
    <Resource Language="am" />
    <Resource Language="th" />
    <Resource Language="kn" />
    <Resource Language="yo-Latn" />
    <Resource Language="uz" />
    <Resource Language="ml" />
    <Resource Language="or" />
    <Resource Language="uk" />
    <Resource Language="pl" />
    <Resource Language="ms" />
    <Resource Language="nl" />
    <Resource Language="ig-Latn" />
    <Resource Language="si" />
    <Resource Language="ne" />
    <Resource Language="ro" />
    <Resource Language="zu" />
    <Resource Language="hr" />
    <Resource Language="el" />
    <Resource Language="hu" />
    <Resource Language="cs" />
    <Resource Language="he" />
    <Resource Language="sv" />
  </Resources>

  <Capabilities>
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>

  <Applications>
    <Application Id="EasyPostDesktop" Executable="EasyPostDesktop\EasyPostDesktop.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Easy-Post Desktop"
        Description="Rate shopping, labels, tracking, and shipping tools for your own EasyPost account."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png" />
    </Application>
  </Applications>
</Package>
